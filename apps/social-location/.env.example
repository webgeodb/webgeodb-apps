# Environment Configuration
WEBGEODB_URL=webgeodb://localhost:27017/social_location
REDIS_URL=redis://localhost:6379
PORT=3000

# Privacy Settings
DEFAULT_PRIVACY_LEVEL=city
DEFAULT_PRIVACY_PRECISION=3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Settings
CACHE_TTL_SECONDS=60
L1_CACHE_SIZE=1000

# WebSocket
WS_PORT=3001
